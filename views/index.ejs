<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>القرآن الكريم</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/quran.css">
</head>
<body>
    <header class="quran-header">
        <h1>القرآن الكريم</h1>
    </header>

    <main class="quran-main" id="main-content">
        <div id="surah-list-container">
            <h2 style="text-align: center;">قائمة السور</h2>
            <div id="surah-list">
                <!-- Surah cards will be loaded here by JavaScript -->
            </div>
        </div>
        <div id="surah-view-container" style="display: none;">
            <button id="back-to-surah-list">العودة إلى قائمة السور</button>
            <h2 id="surah-title"></h2>
            <div id="ayah-view">
                <!-- Ayahs will be loaded here -->
            </div>
        </div>
    </main>

    <footer class="quran-footer">
        <p>تم التطوير بواسطة Jules</p>
    </footer>

    <script src="/js/quran.js"></script>
</body>
</html>
